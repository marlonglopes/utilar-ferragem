# Copy to .env.local and fill in values
# Leave VITE_API_URL empty to use mock data (no backend needed)
VITE_API_URL=
# VITE_API_URL=http://localhost:8090
VITE_CATALOG_URL=
# VITE_CATALOG_URL=http://localhost:8081
VITE_ORDER_URL=
# VITE_ORDER_URL=http://localhost:8082
VITE_AUTH_URL=
# VITE_AUTH_URL=http://localhost:8083

# Stripe — publishable key (test mode). Necessária quando VITE_API_URL é preenchida
# e o payment-service está com PSP_PROVIDER=stripe.
# Conta BR: https://dashboard.stripe.com/acct_1TQFpiLQCtijFcSY/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
