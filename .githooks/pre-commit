#!/usr/bin/env bash
# pre-commit hook: roda go vet + go build em arquivos Go staged
# Instala via: git config core.hooksPath .githooks
#
# Não bloqueia em arquivos não-Go. Pula testes (lentos, rodam em CI).

set -e

staged_go_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$staged_go_files" ]; then
  exit 0
fi

# Identifica os módulos afetados (services/X ou pkg) e roda vet+build em cada
declare -A modules
for f in $staged_go_files; do
  case "$f" in
    services/auth-service/*)    modules["services/auth-service"]=1 ;;
    services/catalog-service/*) modules["services/catalog-service"]=1 ;;
    services/order-service/*)   modules["services/order-service"]=1 ;;
    services/payment-service/*) modules["services/payment-service"]=1 ;;
    pkg/*)                       modules["pkg"]=1 ;;
  esac
done

if [ ${#modules[@]} -eq 0 ]; then
  exit 0
fi

for m in "${!modules[@]}"; do
  echo "▶ $m: go vet + build"
  (cd "$m" && go vet ./... && go build ./...) || {
    echo "✖ $m falhou. Commit abortado."
    exit 1
  }
done

echo "✓ pre-commit OK"
