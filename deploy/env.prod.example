# Template do .env.prod (produção). Copie pra .env.prod na EC2 e preencha.
# NÃO commitar o .env.prod real (segredos).

# --- Banco (RDS) ---
RDS_HOST=utilar-db.xxxxx.sa-east-1.rds.amazonaws.com
DB_USER=utilar
DB_PASSWORD=<senha forte do RDS>

# --- Auth/JWT (32+ chars, aleatório, compartilhado entre os serviços) ---
JWT_SECRET=<openssl rand -base64 48>

# --- CORS (origens do SPA em produção, separadas por vírgula) ---
ALLOWED_ORIGINS=https://utilarferragem.com.br,https://www.utilarferragem.com.br

# --- Pagamento (Appmax) ---
PSP_PROVIDER=appmax
APPMAX_ACCESS_TOKEN=<token do gerente Appmax>
APPMAX_BASE_URL=https://homolog.sandboxappmax.com.br/api/v3   # vazio p/ produção
APPMAX_WEBHOOK_SECRET=

# --- Imagens (ECR) ---
ECR_REGISTRY=<acct>.dkr.ecr.sa-east-1.amazonaws.com
TAG=latest
