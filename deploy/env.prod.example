# Template do .env.prod (produção). Copie pra .env.prod na EC2 e preencha.
# NÃO commitar o .env.prod real (segredos).

# --- Banco (RDS) ---
RDS_HOST=utilar-db.xxxxx.sa-east-1.rds.amazonaws.com
DB_USER=utilar
DB_PASSWORD=<senha forte do RDS>

# --- Auth/JWT (32+ chars, aleatório, compartilhado entre os serviços) ---
# Identidade de USUÁRIO: o auth-service emite, todos os serviços verificam.
JWT_SECRET=<openssl rand -base64 48>

# --- JWT de serviço (A1, auditoria 2026-07-18) ---
# Identidade de SERVIÇO (role=service, tráfego máquina-a-máquina): o
# order-service emite; catalog e auth verificam.
#
# TEM QUE SER UM VALOR DIFERENTE do JWT_SECRET — os serviços se RECUSAM A SUBIR
# se os dois forem iguais, e também se este estiver ausente fora de DEV_MODE.
#
# PORQUÊ dois segredos: com um só, qualquer processo que o possuísse podia
# ASSINAR um token `role=admin` indistinguível do legítimo. O assistant-service
# (Lara) é o mais exposto — endpoint público, texto livre de visitante indo para
# um LLM — e carregava justamente esse poder. Agora ele não recebe este segundo
# segredo: comprometer a Lara deixa de dar acesso administrativo ao catálogo,
# ao pedido e ao pagamento.
#
# Quem recebe: catalog, order, auth. Quem NÃO recebe: assistant, payment.
SERVICE_JWT_SECRET=<openssl rand -base64 48>   # != JWT_SECRET

# --- CORS (origens do SPA em produção, separadas por vírgula) ---
ALLOWED_ORIGINS=https://utilarferragem.com.br,https://www.utilarferragem.com.br

# --- Pagamento (Appmax) ---
PSP_PROVIDER=appmax
APPMAX_ACCESS_TOKEN=<token do gerente Appmax>
APPMAX_BASE_URL=https://homolog.sandboxappmax.com.br/api/v3   # vazio p/ produção
APPMAX_WEBHOOK_SECRET=

# --- Assistente (Lara) ---
# Vazio = Lara em modo mock (regras + busca real no catálogo). Com chave = Claude.
ANTHROPIC_API_KEY=
LARA_MODEL=claude-opus-4-8

# --- Imagens (ECR) ---
ECR_REGISTRY=<acct>.dkr.ecr.sa-east-1.amazonaws.com
TAG=latest
